# ============================================================
# PRONEA v4.0 — Variables de Entorno
# Copia este archivo como .env.local y rellena con tus valores
# NUNCA subas .env.local a GitHub
# ============================================================

# Supabase → Settings → API de tu proyecto
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...clave_publica
SUPABASE_SERVICE_ROLE_KEY=eyJ...clave_PRIVADA_solo_servidor

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cadena_aleatoria_32_caracteres_minimo

# URL de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000
