name: Generate package-lock.json

on:
  workflow_dispatch:

jobs:
  generate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '24'
      - run: npm install
      - run: cat package-lock.json > /dev/null
      - uses: actions/upload-artifact@v4
        with:
          name: package-lock
          path: package-lock.json
